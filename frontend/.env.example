# Shared password gating /submit and POSTs to /api/runs.
# Set in Amplify env vars, NEVER commit a real value.
DEMO_PASSWORD=

# Backend Lambda invoke URL (provisioned by CDK in infra/).
# Leave empty in local dev to use the in-process mock backend.
NEXT_PUBLIC_BACKEND_URL=

# Cookie used to remember a successful password entry. Random string,
# at least 32 chars. Generate once with: openssl rand -hex 32
AUTH_COOKIE_SECRET=

# Optional: signal to the backend that we're in deployed mode (HITL off).
JOB_PIPELINE_DEPLOYED=true
